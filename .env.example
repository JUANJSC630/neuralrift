# ┌─────────────────────────────────────────────────────────────┐
# │  NeuralRift — Environment Configuration                    │
# │  Copy to .env and fill in the values for your environment  │
# └─────────────────────────────────────────────────────────────┘

# ── App ───────────────────────────────────────────────────────
APP_NAME=NeuralRift
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://neuralrift.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file

# ── Site (public-facing brand values) ─────────────────────────
SITE_NAME="${APP_NAME}"
SITE_URL="${APP_URL}"
SITE_EMAIL=hola@neuralrift.com
SITE_DESCRIPTION="Guías técnicas, reviews honestas y estrategias para developers y freelancers que quieren construir mejores productos con tecnología e IA."
SITE_TAGLINE="Tecnología, IA y herramientas para construir mejor"
SITE_TWITTER="@neuralrift"
SITE_AUTHOR="Juan Jose"

# ── Security ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database (MySQL on Railway) ───────────────────────────────
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=null

# ── Session ───────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=neuralrift.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ── Cache & Queue ─────────────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local
MEDIA_DISK=public

# ── Mail (SMTP) ──────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="${SITE_EMAIL}"
MAIL_FROM_NAME="${APP_NAME}"

# ── Mail — Resend (alternative to SMTP) ──────────────────────
# MAIL_MAILER=resend
# RESEND_API_KEY=
# MAIL_FROM_ADDRESS="${SITE_EMAIL}"
# MAIL_FROM_NAME="${APP_NAME}"

# ── Sentry (error monitoring) ───────────────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ── AI Provider ──────────────────────────────────────────────
AI_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Analytics (optional) ─────────────────────────────────────
ANALYTICS_ID=

# ── AWS / S3 (optional — only if using S3 for media) ─────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Horizon (optional — only if running Horizon) ─────────────
# HORIZON_DOMAIN=
# HORIZON_PATH=horizon

# ── Vite ──────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_SENTRY_DSN="${SENTRY_LARAVEL_DSN}"